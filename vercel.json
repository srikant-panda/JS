{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/js-learn/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "artifacts/js-learn/dist/public" }
    }
  ],
  "outputDirectory": "artifacts/js-learn/dist/public",
  "routes": [
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
